 120          // ================= ADC采集 & 数据刷新 (每约250ms, <0.5s满足要求) =================
 121          void Adc_run(void)
 122          {
 123   1          if(v_cnt >= 500)
 124   1              {
 125   2                      v_cnt = 0;
 126   2                      EA = 0;
 127   2                       if(show_mode == DISP_V)
 128   2                      {
 129   3                      if(v_mode == 0)
 130   3                      {               
 131   4                              // 始终读取ADC，计算电压和频率
 132   4                              voltage = Get_ADC12bitResult(3);
 133   4                              voltage = (250UL * voltage) / 4096;          // 0~250 (0~2.50V)                         
 134   4                      }
 135   3                      else
 136   3                      {
 137   4                              voltage = 100;                           // 显示固定1.00V
 138   4                      }
 139   3                      }
 140   2                      else
 141   2                      {
 142   3                              voltage = Get_ADC12bitResult(3);
 143   3                              set_freq = (999999UL * voltage) / 4095UL; 
 144   3                              if(set_freq > 999999) set_freq = 999999;     // 钳位到0~999999
 145   3                              Timer2_SetFreq(set_freq);
 146   3                      }
 147   2      
 148   2                      EA = 1; 
 149   2              }
 150   1      }
