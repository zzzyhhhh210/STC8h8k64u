 152          // ================= 按键处理 (S4~S7) =================
 153          void Key_Run(void)
 154          {
 155   1          key = Key_scan();
 156   1          switch(key) {
 157   2      
 158   2                      // S4: 显示界面切换 (电压<-->频率)
 159   2              case 4:show_mode = !show_mode;
 160   2                  break;
 161   2      
 162   2                      // S5: DAC模式切换 (跟随W2 <--> 固定1.0V)        
 163   2                      case 5:v_mode = !v_mode;
 164   2                  if(v_mode == 1) voltage = 100;     // 切到固定模式时显示1.00V
 165   2                  break;
 166   2      
 167   2                      // S6: LED指示灯开关
 168   2              case 6:led_mode = !led_mode;
 169   2                  break;
 170   2      
 171   2                      // S7: 数码管开关
 172   2              case 7:seg_mode = !seg_mode;
 173   2                  break;
 174   2      
 175   2              default: break; 
 176   2          }
 177   1      }
