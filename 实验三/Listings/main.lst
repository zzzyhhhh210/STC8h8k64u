  55          // ================= Timer1中断 (500us, 时基+频率测量门控) =================
  56          void timer1() interrupt 3
  57          {
  58   1          TL1 = 0x18;                 // 手动重装: 65536-1000=64536=0xFC18
  59   1          TH1 = 0xFC;
  60   1      
  61   1          freq_cnt++;
  62   1              v_cnt++;
  63   1          
  64   1          if(v_cnt & 0x01)            // 奇数tick: 数码管扫描
  65   1          {                           
  66   2              if(seg_mode == 0)
  67   2                  Seg_Scan();
  68   2                      if(freq_cnt >= 1000) 
  69   2                              {    
  70   3                                      freq_cnt = 0;
  71   3                                      freq= set_freq;
  72   3      //                              Timer2_SetFreq(set_freq);
  73   3                              }
  74   2      
  75   2          } 
  76   1          else                        // 偶数tick: LED刷新
  77   1          {                           
  78   2              P7 = 0xFF;              // 先关位选
  79   2              P6 = 0xFF;              // ★清P6再切电源, 防止段码串扰LED
  80   2              P40 = 0;                // 开LED电源(清空后再开)
  81   2              Led_Run();
  82   2          }
  83   1              
  84   1      }
  85          // ================= 显示缓存更新 =================
  86          void Seg_Run(void)
  87          {
  88   1          uint8_t i;
  89   1      
  90   1          if(show_mode == DISP_V)
  91   1          {
  92   2                      v_char[7] = LedChar[voltage % 10];
  93   2                      v_char[6] = LedChar[voltage / 10 % 10];
  94   2                      v_char[5] = LedChar[voltage / 100] & 0x7F;
  95   2              for(i = 0; i < 8; i++)
  96   2                  LedBuff[i] = v_char[i];
  97   2          } 
  98   1          else if(show_mode == DISP_F)
  99   1          {
 100   2              // 6位频率数字 (位置2~7)
 101   2              f_char[2] = LedChar[freq / 100000 % 10];
 102   2              f_char[3] = LedChar[freq / 10000 % 10];
 103   2              f_char[4] = LedChar[freq / 1000 % 10];
 104   2              f_char[5] = LedChar[freq / 100 % 10];
 105   2              f_char[6] = LedChar[freq / 10 % 10];
 106   2              f_char[7] = LedChar[freq % 10];
 107   2      
 108   2              // 前导零熄灭 (位置2~6, 位置7始终保留最低位)
 109   2              for(i = 2; i < 7; i++)
 110   2              {
 111   3                  if(f_char[i] != 0xC0) break;
 112   3                  else f_char[i] = 0xFF;
 113   3              }
 114   2              
 115   2              for(i = 0; i < 8; i++)
 116   2                  LedBuff[i] = f_char[i];
