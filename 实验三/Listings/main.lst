 179          // ================= LED指示灯 (P6口, 低电平点亮) =================
 180          // L1=P6.0: 电压测量指示    L2=P6.1: 频率测量指示
 181          // L3=P6.2: 电压阈值指示    L4=P6.3: 频率阈值指示
 182          // L5=P6.4: DAC模式指示    L6~L8: 未使用(始终熄灭)
 183          void Led_Run(void)
 184          {
 185   1          uint8_t led_val;
 186   1          
 187   1          if(led_mode == 1)
 188   1          {
 189   2              // LED功能关闭: 全部熄灭
 190   2              P6 = 0xFF;               // ★先清P6
 191   2              P40 = 1;                 // 再关LED电源(清空后再关, 防止段码闪一下)
 192   2              return;
 193   2          }
 194   1          
 195   1          // LED功能启用 (P7/P6/P40已在Timer0 ISR中处理好)
 196   1          led_val = 0xFF;              // 默认全部熄灭(bit=1灭, bit=0亮)
 197   1          
 198   1          // L1/L2: 显示模式指示
 199   1          if(show_mode == DISP_V)
 200   1              {
 201   2              led_val &= ~0x01;        // L1亮(电压模式), L2灭
 202   2                      // L3: 电压阈值指示
 203   2          // VW2<0.6V:灭, 0.6≤VW2<1.2V:亮, 1.2≤VW2<1.8V:灭, VW2≥1.8V:亮
 204   2          // voltage单位是10mV, 即阈值 60=0.6V, 120=1.2V, 180=1.8V
 205   2                              if((voltage >= 60 && voltage < 120) || (voltage >= 180))
 206   2                              led_val &= ~0x04;        // L3亮
 207   2          // L5: DAC模式指示 (VW2跟随模式亮, 固定1.0V模式灭)
 208   2          if(v_mode == 0)
 209   2              led_val &= ~0x10;        // L5亮(DAC跟随W2)
 210   2              }
 211   1      
 212   1          else
 213   1              {
 214   2                      led_val &= ~0x02;        // L2亮(频率模式), L1灭        
 215   2          // L4: 频率阈值指示
 216   2          // F<1KHz:灭, 1KHz≤F<5KHz:亮, 5KHz≤F<10KHz:灭, F≥10KHz:亮
 217   2          if((freq >= 1000 && freq < 5000) || (freq >= 10000))
 218   2              led_val &= ~0x08;        // L4亮
 219   2          }
 220   1          
 221   1          // L6~L8:熄灭
 222   1          P6 = led_val;
 223   1      }


