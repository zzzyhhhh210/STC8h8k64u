   1          #include <stc8h.h>
   2          #include "Nix.h"
   3          #include "delay.h"
   4          #include "Timer.h"
   5          #include "Key.h"
   6          
   7          unsigned char cnt;
   8          unsigned char key;
   9          int sec = 0;
  10          /*
  11          99跑马表（0-99）
  12          1.数码管
  13          2.定时器中断
  14          */
  15           int main(void)
  16          {  
  17   1              Key_Init();
  18   1              Timer1_Init();
  19   1            while(1)
  20   1            {
  21   2                      key = Key_scan();
  22   2                      P6=0XFF;
  23   2                      P7=0xfe;   
  24   2                      Delay_us(10);
  25   2                      P6 = Nix[sec%10];
  26   2                      Delay_ms(5);//保证数码管显示稳定，避免闪烁
  27   2                        
  28   2                      P6=0XFF;
  29   2                      P7=0xfd;    
  30   2                      Delay_us(10);
  31   2                      P6 = Nix[sec/10];
  32   2                      Delay_ms(5);//保证数码管显示稳定，避免闪烁      
  33   2                        
  34   2                      if(key == 0)TR0 = 0;
  35   2                      if(key == 1)TR0 = 1;//EA,ET0，IE                
  36   2                      if(key == 2){sec++;if(sec>99)sec=0;}
  37   2                      if(key == 3){sec--;if(sec<0)sec=99;}
  38   2                      if(key == 4)sec = 0;
  39   2            }
  40   1                
  41   1      }
