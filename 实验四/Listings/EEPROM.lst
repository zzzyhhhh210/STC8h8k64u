   1          #include "EEPROM.h"
   2          
   3          extern unsigned char time;
   4          /**
   5           * @brief 向 EEPROM 写入一个字节
   6           * @param add: 地址
   7           * @param date: 数据
   8           */
   9          void eeprom_write(uint8_t add,uint8_t date)
  10          {
  11   1              I2C_Start();
  12   1              I2C_SendData(EEPROM_ADDR_WRITE);// 设备地址 + 写
  13   1              I2C_RecvACK();
  14   1      
  15   1              I2C_SendData(add);// 内存地址
  16   1              I2C_RecvACK();
  17   1      
  18   1              I2C_SendData(date);// 【关键修复】发送要写入的数据
  19   1              I2C_RecvACK();
  20   1      
  21   1              I2C_Stop();
  22   1          // EEPROM 写入周期通常为 5ms - 10ms
  23   1          // 必须延时，否则下一次读写会失败
  24   1              I2C_Delay();
  25   1      }
  26          
  27          /**
  28           * @brief 从 EEPROM 读取一个字节
  29           * @param add: 地址
  30           * @return: 数据
  31           */
  32          uint8_t eeprom_read(uint8_t add)
  33          {
  34   1              uint8_t date;
  35   1      
  36   1                // 1. 伪写：设置读取地址指针
  37   1              I2C_Start();
  38   1              I2C_SendData(EEPROM_ADDR_WRITE);// 设备地址 + 写
  39   1              I2C_RecvACK();
  40   1      
  41   1              I2C_SendData(add); // 内存地址
  42   1              I2C_RecvACK();
  43   1      
  44   1               // 2. 重复启动：开始读取
  45   1              I2C_Start();
  46   1              I2C_SendData(EEPROM_ADDR_READ);// 设备地址 + 读
  47   1              I2C_RecvACK();
  48   1      
  49   1               // 3. 接收数据
  50   1              date=I2C_RecvData();
  51   1      
  52   1               // 4. 发送 NAK 并停止
  53   1              I2C_SendNAK(); // 最后一个字节发送 NAK
  54   1              I2C_Stop();
