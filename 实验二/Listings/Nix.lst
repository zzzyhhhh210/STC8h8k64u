  19          void Nix_Num(uint_8 digit, uint_8 Number)     
  20          {
  21   1          P6 = 0x00; // 消影
  22   1          
  23   1          if(digit < 1 || digit > 8) return;
  24   1      
  25   1          // 位选：低电平有效
  26   1          P7 = T_COM[digit]; 
  27   1          
  28   1          // 段选
  29   1          if(Number <= 9)
  30   1              P6 = Nix[Number];
  31   1          else
  32   1              P6 = 0xFF; 
  33   1              
  34   1          Delay_ms(1);  
  35   1          P6 = 0x00; // 消影
  36   1          P7 = 0xFF; // 关闭位选
  37   1      }   
  38          
  39          void Nix_Display(unsigned char *buf)
  40          {
  41   1          static unsigned char pos = 0;
  42   1          
  43   1          P7 = 0xFF; // 消影
  44   1          P6 = Nix[buf[pos]]; 
  45   1          P7 = ~(0x01 << pos); 
  46   1          pos = (pos + 1) % 8;
  47   1          Delay_ms(1); 
  48   1      }
