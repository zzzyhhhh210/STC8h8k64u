 306          // ================= LED流水灯运行 =================
 307          void Led_Run(void)
 308          {
 309   1              //问题卡死在led为模式1
 310   1              //      led_mode = Set_led_mode;
 311   1          // 只在模式变化时同步，不每次覆盖！
 312   1          if(mode == set_mode)
 313   1          {
 314   2              if(led_mode != Set_led_mode)
 315   2              {
 316   3                  led_mode = Set_led_mode;
 317   3                  index = 0;  // 模式切换时复位位置
 318   3              }
 319   2          }
 320   1          switch(led_mode)
 321   1          {
 322   2              //模式1:L1→L8左到右单循环
 323   2              case 1:P6_OUT = _cror_(0x7F, index);index++;
 324   2                  if(index >= 8){index = 0;led_mode = 2;}
 325   2                  break;
 326   2              //模式2:L8→L1右到左单循环
 327   2              case 2:P6_OUT = _crol_(0xFE, index);index++;
 328   2                  if(index >= 8){index = 0;led_mode = 3;}
 329   2                  break;
 330   2              //模式3:L1+L8→L2+L7→L3+L6→L4+L5双向汇聚
 331   2              case 3:P6_OUT = _cror_(0x7F, index) & _crol_(0xFE, index);index++;
 332   2                  if(index >= 4){index = 0;led_mode = 4;}
 333   2                  break;
 334   2              //模式4:L4+L5→L3+L6→L2+L7→L1+L8双向发散
 335   2              case 4:P6_OUT = _crol_(0xEF, index) & _cror_(0xF7, index);index++;
 336   2                  if(index >= 4){index = 0;led_mode = 1;}
 337   2                  break;
 338   2              default:led_mode = 1;index = 0;
 339   2                  break;
 340   2          }
 341   1      }            
